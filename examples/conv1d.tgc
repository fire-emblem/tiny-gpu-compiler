// conv1d.tgc — 1D convolution with sliding window
// Tests for-loops and accumulation

kernel conv1d(global int* output, global int* input, global int* coeffs) {
    int idx = blockIdx * blockDim + threadIdx;
    int sum = 0;
    for (int k = 0; k < 3; k++) {
        sum = sum + input[idx + k] * coeffs[k];
    }
    output[idx] = sum;
}
